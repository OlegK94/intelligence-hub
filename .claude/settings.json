{
  "autoCompactEnabled": true,
  "cleanupPeriodDays": 90,
  "permissions": {
    "allow": [
      "Bash(python3 tools/*)",
      "Bash(bash scripts/*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git fetch*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(qmd*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(rg*)",
      "Bash(wc*)",
      "Bash(find . -name*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(curl* | bash*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/scripts/status-line.sh\"",
    "refreshInterval": 60
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/scripts/session-start.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/scripts/pre-compact.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/scripts/bash-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/scripts/on-file-change.sh\" 2>> \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/outputs/notes/hooks.log\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/scripts/post-session.sh\" 2>> \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/outputs/notes/hooks.log\"",
            "async": true
          },
          {
            "type": "command",
            "command": "bash \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/scripts/notify-email.sh\" 2>> \"/Users/$(whoami)/Library/Mobile Documents/com~apple~CloudDocs/IntelligenceHub/outputs/notes/hooks.log\"",
            "async": true
          }
        ]
      }
    ]
  }
}
